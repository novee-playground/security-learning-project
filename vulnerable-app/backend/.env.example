# 環境変数の例
# 本番環境では絶対に使用しないでください！

# サーバー設定
NODE_ENV=development
PORT=3000

# PostgreSQL データベース設定
DB_HOST=postgres
DB_PORT=5432
DB_USER=vulnapp
DB_PASSWORD=insecure_password_123
DB_NAME=vulnerable_app

# MongoDB 設定
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=vulnapp
MONGO_PASSWORD=insecure_password_123
MONGO_DB=vulnerable_app

# JWT 設定（意図的に弱い秘密鍵）
JWT_SECRET=weak_secret_key
JWT_EXPIRES_IN=24h

# セッション設定（意図的に弱い秘密鍵）
SESSION_SECRET=weak_session_secret
SESSION_MAX_AGE=86400000

# CORS 設定（意図的に緩い設定）
CORS_ORIGIN=*

# API キー（意図的に露出）
API_KEY=exposed_api_key_12345

# ファイルアップロード設定
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ログ設定
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# セキュリティ設定（意図的に無効化）
ENABLE_RATE_LIMIT=false
ENABLE_HELMET=false
ENABLE_CSRF_PROTECTION=false
ENABLE_INPUT_VALIDATION=false

# デバッグモード（意図的に有効化）
DEBUG=true
VERBOSE_ERRORS=true